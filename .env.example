# Telegram Bot
TELEGRAM_TOKEN=your_token_here

# LLM Provider
LLM_PROVIDER=ollama

# Ollama connection
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Context size (how much conversation model can see)
OLLAMA_NUM_CTX=2048

# Maximum generated tokens
OLLAMA_NUM_PREDICT=512

# Creativity / randomness
OLLAMA_TEMPERATURE=0.3

# Ollama health check timeout (seconds)
OLLAMA_HEALTH_TIMEOUT=10

# Enable/disable model thinking mode
OLLAMA_THINK=false

# Database

DATABASE_DRIVER=sqlite
DATABASE_URL=file:storage.db